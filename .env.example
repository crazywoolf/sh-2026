# LLM-провайдер (OpenAI-совместимый API)

# --- Вариант A: Yandex AI Studio (YandexGPT) ---
LLM_BASE_URL=https://ai.api.cloud.yandex.net/v1
LLM_API_KEY=<значение API-ключа из AI Studio>
LLM_MODEL=gpt://<folder-id>/yandexgpt-5.1
LLM_AUTH=bearer
# folder-id извлекается из URI модели автоматически (или задать LLM_PROJECT).
# Дешевле/быстрее для простых агентов: gpt://<folder-id>/yandexgpt-5-lite

# --- Вариант B: OpenAI (или другой совместимый) ---
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_API_KEY=sk-...
# LLM_MODEL=gpt-4o-mini
# LLM_AUTH=bearer

PORT=8000
MERIDIAN_DB=db/meridian.duckdb

# Мониторинг запросов (страница /monitor)
MONITOR_TTL_MIN=60
MONITOR_LOG_DIR=logs

# Отчёты по расписанию (этап 5)
SCHEDULE_CRON=0 9 * * 1
# опциональная доставка отчёта:
# REPORT_WEBHOOK=https://example/hook
# TELEGRAM_BOT_TOKEN=...
# TELEGRAM_CHAT_ID=...
